@page
@model SecureCatalog.Pages.Products.CreateModel
@{
    ViewData["Title"] = "Crear Producto";
}

<h1>Crear Nuevo Producto</h1>

<div class="form-container">
    <form method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="Input.Nombre"></label>
            <input asp-for="Input.Nombre" class="form-control" />
            <span asp-validation-for="Input.Nombre" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Precio"></label>
            <input asp-for="Input.Precio" class="form-control" type="number" step="0.01" min="0.01" />
            <span asp-validation-for="Input.Precio" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Descripcion"></label>
            <textarea asp-for="Input.Descripcion" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Input.Descripcion" class="text-danger"></span>
        </div>

        <div class="actions-bar">
            <button type="submit" class="btn btn-primary">Crear</button>
            <a href="/Products" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>
